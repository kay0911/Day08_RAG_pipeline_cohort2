# OpenAI (Task 10 - Generation)
OPENAI_API_KEY=sk-xxx

# Anthropic Claude (Task 10 - Alternative to OpenAI)
# ANTHROPIC_API_KEY=sk-ant-xxx

# Jina AI (Task 7 - Cross-encoder reranking, optional)
# JINA_API_KEY=jina_xxx

# PageIndex (Task 8 - Vectorless RAG)
# Sign up at: https://pageindex.ai/
PAGEINDEX_API_KEY=pi_xxx
PAGEINDEX_INDEX_ID=

# Weaviate Cloud (not used — we use ChromaDB locally)
# WEAVIATE_URL=https://xxx.weaviate.network
# WEAVIATE_API_KEY=xxx
